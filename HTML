 <div class="loading">
    <div class="loading-page">
      <div class="main-loading">
        <label for="" class="element">Yükleniyor
          <label for="" class="point-loading">.</label>
          <label for="" class="point-loading">.</label>
          <label for="" class="point-loading">.</label>
        </label>
      </div>
    </div>
  </div>
  <div class="main">
    <div class="toogle-switch">
      <label class="switch">
        <input type="checkbox">
        <span class="slider round"></span>
      </label>
    </div>
    <div class="calculator">
      <div class="cal-result">
        <input type="text" class="input-value" value="" disabled>
      </div>
      <div class="cal-body">
        <button type="button" class="btn same clear bg-thema" value="clear"><img src="delete.svg"
            class="clear clear-img" value="clear" height='38px' alt=""><span class="ac clear">AC</span></button>
        <button type="button" id="backspace" class="btn same delete color bg-thema"><img src="arrow.svg" id="backspace"
            height="38px" alt=""></button>
        <button type="button" class="btn operator same color bg-thema" value="/">/</button>
        <button type="button" class="btn  operator same color operator-bg" value="*">X</button>
        <button type="button" class="btn operator same color minus operator-bg" value="-">-</button>
        <button type="button" class="btn operator same plus color operator-bg" value="+">+</button>
        <button type="button" class="btn same point " value=".">.</button>
        <button type="button" class="btn operator equal operator-bg" value="=">=</button>

        <button type="button" class="btn num same btn-number" value="7">7</button>
        <button type="button" class="btn num same btn-number" value="8">8</button>
        <button type="button" class="btn num same btn-number" value="9">9</button>

        <button type="button" class="btn num same btn-number" value="4">4</button>
        <button type="button" class="btn num same btn-number" value="5">5</button>
        <button type="button" class="btn num same btn-number" value="6">6</button>

        <button type="button" class="btn num same btn-number" value="1">1</button>
        <button type="button" class="btn num same btn-number" value="2">2</button>
        <button type="button" class="btn num same btn-number" value="3">3</button>
        <button type="button" class="btn  zero num  decimal btn-number" value="0">0</button>
      </div>
    </div>
    <div class="change">
      <button class="change-btn"> Temayi Değiştir</button>
    </div>
  </div>
